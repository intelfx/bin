#!/bin/bash

set -eo pipefail
shopt -s lastpipe
shopt -s nullglob

log() {
	echo ":: $*" >&2
}

err() {
	echo "E: $*" >&2
}

die() {
	err "$@"
	exit 1
}

usage() {
	if (( $# )); then
		echo "${0##*/}: $*" >&2
		echo >&2
	fi
	_usage >&2
	exit 1
}

_usage() {
	cat <<EOF
Usage: ${0##*/}
EOF
}


#
# git-gc-fetch -- `git gc` after fetching many redundant packs
#


#
# args
#

now="$(date +%s)"
SMALL_PACK_BYTES="$(( 100*1024*1024 ))"
OLD_PACK_TIME="$(( now - 24*3600 ))"
GIT_GC=0
GIT_GC_NO_PRUNE=0
GIT_GEOMETRIC=0
FORCE=0
PACK_ARGS=()

if args=$(getopt -o '+S:T:s:gbmf' --long 'size:,time:,seconds:,gc,gc-no-prune,geometric,bitmap,midx,force' -n "${0##*/}" -- "$@"); then
	eval set -- "$args"
else
	usage
fi
unset args

while :; do
	case "$1" in
	-S|--size) shift; SMALL_PACK_BYTES="$(bscalcq -b "$1")" ;;
	-T|--time) shift; OLD_PACK_TIME="$(date -d "$1" +%s)" ;;
	-s|--seconds) shift; OLD_PACK_TIME="$(( now - "$1" ))" ;;
	--gc) GIT_GC=1 ;;
	--gc-no-prune) GIT_GC_NO_PRUNE=1 ;;
	-g|--geometric) GIT_GEOMETRIC=1 ;;
	-b|--bitmap) PACK_ARGS+=( --write-bitmap-index ) ;;
	-m|--midx) PACK_ARGS+=( --write-midx ) ;;
	-f|--force) FORCE=1 ;;
	--) shift; break ;;
	*) die "getopt error" ;;
	esac
	shift
done

# case "$#" in
# 0) ;;
# *) usage "wrong number of positional arguments" ;;
# esac


#
# functions
#

join() {
	local IFS
	IFS="$1"
	shift
	echo "$*"
}


#
# main
#

GIT_DIR="$(git rev-parse --git-common-dir)"

cleanup() {
	rm -f "$GIT_DIR/objects/pack"/*.keep
}
trap cleanup EXIT

declare -a PACKS

find "$GIT_DIR/objects/pack" \
	-type f \
	\( -name '*.pack' -or -name 'tmp_pack_*' \) \
| while read pack; do

	mtime="$(stat -c '%Y' "$pack")"
	size="$(stat -c '%s' "$pack")"

	# HACK: use the older of .pack and .idx mtimes.
	# Sometimes, `git fetch` touches old packs for no good reason, breaking
	# this logic.
	if [[ $pack == *.pack ]]; then
		idx="${pack%.pack}.idx"
		mtime_pack="$mtime"
		mtime_idx="$(stat -c '%Y' "$idx")"
		mtime="$(( mtime_idx < mtime_pack ? mtime_idx : mtime_pack ))"
	fi

	PACKS+=(
		"$(join $'\t' "$mtime" "$size" "$pack")"
	)
done

if ! [[ ${PACKS+set} ]]; then
	echo "Nothing to pack"
	exit
fi

CANDIDATES=0

if (( ! GIT_GEOMETRIC ))
then _sort_args=(-k1)     # by mtime, ascending
else _sort_args=(-k2 -r)  # by size, descending
fi

NR=0
printf "%s\n" "${PACKS[@]}" \
| sort -n -t $'\t' "${_sort_args[@]}" \
| while read -r mtime size pack; do

	idx="${pack%.pack}.idx"

	human_size="$(du --human-readable --apparent-size "$pack" | cut -d$'\t' -f1)"
	human_mtime="$(date -d "@$mtime")"

	if [[ $pack == */tmp_pack_* ]]; then
		echo "Temporary pack, forcing: ${pack##*/} @ $human_size ($human_mtime)"
		(( ++CANDIDATES ))
		FORCE=1
		continue
	fi

	cruft="${pack%.pack}.mtimes"
	if [[ -e $cruft ]]; then
		echo "Skipping cruft pack: ${pack##*/} @ $human_size ($human_mtime)"
		continue
	fi

	# in geometric mode, repack everything after the largest pack
	if (( GIT_GEOMETRIC && NR > 0 )); then
		repack=1

	# repack everything after the first candidate pack
	elif (( CANDIDATES )); then
		repack=1

	# repack all recent packs
	elif (( mtime > OLD_PACK_TIME )); then
		repack=1

	# do not bother keeping very small packs
	elif (( size < SMALL_PACK_BYTES )); then
		repack=1

	# keep the rest
	else
		repack=0
	fi

	if (( repack )); then
		echo "Repacking: ${pack##*/} @ $human_size ($human_mtime)"
		(( ++CANDIDATES ))
	else
		echo "Keeping pack: ${pack##*/} @ $human_size ($human_mtime)"
		touch "${pack%.pack}.keep"
	fi

	(( ++NR ))
done

if (( !FORCE && CANDIDATES < 2 )); then
	echo "Nothing to repack"
	exit
fi

if (( GIT_GC || GIT_GC_NO_PRUNE )); then
	if (( ! GIT_GC_NO_PRUNE ))
	then
		_gc_cfg=(
			-c gc.pruneExpire=now
		); _gc_args=(
			--prune=now
		)
	else
		_gc_cfg=(
			-c gc.cruftPacks=true
			-c gc.pruneExpire=never
			-c gc.reflogExpire=never
			-c gc.reflogExpireUnreachable=never
		); _gc_args=(
			--no-prune
		)
	fi
	git \
		-c pack.depth=50 -c pack.window=1000 \
		-c gc.writeCommitGraph=true \
		"${_gc_cfg[@]}"
		gc \
		--keep-largest-pack \
		"${_gc_args[@]}" \
		"$@"
else
	if (( ! GIT_GEOMETRIC ))
	then _repack_args=( --cruft )
	else _repack_args=( -g2 )
	fi
	git \
		repack \
		"${_repack_args[@]}" -d -l \
		-fF --depth=50 --window=1000 \
		"${PACK_ARGS[@]}" \
		"$@"
	# git \
	# 	multi-pack-index \
	# 	write \
	# 	--bitmap
	git \
		commit-graph \
		write \
		--reachable
fi

rm -vf "$GIT_DIR/objects/pack"/tmp_pack_*
