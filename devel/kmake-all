#!/bin/bash
#
# kbuild-all: build the kernel and userspace tools, then produce a merged
#             compile_commands.json covering both.
#
# Usage:  ./kbuild-all [extra kmake args...]
#
# Extra arguments (e.g. "W=1") are forwarded to the kernel build only.
#

set -eo pipefail
shopt -s lastpipe
shopt -s extglob

log() {
	echo ":: $*" >&2
}

err() {
	echo "E: $*" >&2
}

die() {
	err "$@"
	exit 1
}

usage() {
	if (( $# )); then
		echo "${0##*/}: $*" >&2
		echo >&2
	fi
	_usage >&2
	exit 1
}

_usage() {
	cat <<EOF
Usage: ${0##*/} [-h|--help]
       ${0##*/} [--COMPONENT[=TARGETS] ...] [MAKE-FLAGS]

Options:
	--COMPONENT[=TARGETS]	When specified, build only these binaries
				(and do not generate a compile_commands.json).
				When TARGETS are specified, replace the
				default make(1) targets when building this binary.

				(when no COMPONENTs are specified, build all
				binaries and generate compile_commands.json)

	MAKE-FLAGS		Append specified Make flags and variables
				to all make(1) invocations.

Possible COMPONENTs:
	-k | --kernel		build the kernel
	-u | --user		build all userspace targets below
	--perf			build the perf(1) tool
	--cpupower		build the cpupower(1) tool
	--x86			build the x86_energy_perf_policy(8) tool
	--usbip			build the usbip(8) and usbipd(8) tools
	--turbostat		build the turbostat(8) tool
	--bpf			build the bpftool(8) and other tools
	--tmon			build the tmon tool
	--bpf			build the hv_* tools
	--bootconfig		build the bootconfig tool
	--intel-sst		build the intel-speed-select tool
	--kcpuid		build the kcpuid tool


EOF
}


#
# args
#

if args=$(getopt -o 'hk::u::' --long 'help,kernel::,user::,perf::,cpupower::,x86::,usbip::,tmon::,turbostat::,hv::,bpf::,bootconfig::,intel-sst::,kcpuid::' -n "${0##*/}" -- "$@"); then
	eval set -- "$args"
else
	usage
fi
unset args

declare -a COMPONENTS=(
	kernel
	user
	perf
	x86
	usbip
	tmon
	turbostat
	hv
	bpf
	bootconfig
	intel-sst
	kcpuid
)
declare -A WANTS
declare -A TARGETS

#
while :; do
	if [[ $1 == -h || $1 == --help ]]; then
		ARG_HELP=1
		shift; continue
	fi
	for c in "${COMPONENTS[@]}"; do
		if [[ "$1" == "--$c" \
		   || "$1" == "-${c:0:1}" && $c == @(kernel|user) ]]; then
			WANTS[$c]=1
			if [[ $2 ]]; then
				TARGETS[$c]="$2"
			fi
			shift 2; continue 2
		elif [[ $1 == -- ]]; then
			shift; break 2
		fi
	done
	die "getopt error: $1"
done

if [[ ${WANTS[user]+set} ]]; then
	for c in "${COMPONENTS[@]}"; do
		case "$c" in
		kernel|user) ;;
		*) WANTS[$c]=1; TARGETS[$c]="${TARGETS[user]}" ;;
		esac
	done
fi

ARG_MAKEVARS=("$@")

want() {
	# either nothing set (build everything), or want to build this specific thing
	(( ! "${#WANTS[@]}" || "${WANTS[$1]:-0}" ))
}

want_cdb() {
	# only generate compile_commands.json when building everything
	(( ! "${#WANTS[@]}" ))
}


# ---------------------------------------------------------------------------
# Common variables and setup
# ---------------------------------------------------------------------------

SRCDIR="$PWD"
if ! [[ -e "$SRCDIR/Makefile" && -e "$SRCDIR/Kbuild" && -e "$SRCDIR/Kconfig" ]]; then
	die "Not a Linux kernel source tree: ${SRCDIR@Q}"
fi

CDB="$SRCDIR/compile_commands.json"

# bear invocation: append every tools build into the kernel's compile database
BEAR=(bear --output "$CDB" --append --)

# kernel targets: build everything by default
KERNEL_TARGETS=(all)

if [[ ${TARGETS[kernel]} ]]; then
	read -ra KERNEL_TARGETS <<<"${TARGETS[kernel]}"
fi

# generate compile_commands.json if desired
if want_cdb; then
	# kernel build: also generate compile_commands.json
	KERNEL_TARGETS+=(compile_commands.json)
else
	# skip bear
	BEAR=()
fi

# other variables to pass to make for reproducibility and ccache-friendliness
MAKEVARS=(
	"-j$(nproc)"
	SOURCE_DATE_EPOCH=0
	KBUILD_BUILD_TIMESTAMP="$(date -Ru -d '@0')"
	KBUILD_BUILD_HOST=archlinux
	KBUILD_BUILD_USER=linux
)
if [[ -e "$SRCDIR/version" ]]; then MAKEVARS+=(
	KERNELRELEASE="$(< "$SRCDIR/version")"
); fi


# ---------------------------------------------------------------------------
# Default compiler / flags for userspace builds (not the kernel)
# ---------------------------------------------------------------------------

: "${CC=clang}"
: "${CXX=clang++}"
: "${CFLAGS=-march=native -pipe -fno-plt -fexceptions -Wformat -Werror=format-security -fstack-clash-protection -fcf-protection -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer -O0 -ggdb3}"
: "${CXXFLAGS=-march=native -pipe -fno-plt -fexceptions -Wformat -Werror=format-security -fstack-clash-protection -fcf-protection -Wp,-D_GLIBCXX_ASSERTIONS -fno-omit-frame-pointer -mno-omit-leaf-frame-pointer -O0 -ggdb3}"
: "${LDFLAGS=-Wl,-O1 -Wl,--sort-common -Wl,--as-needed -Wl,-z,relro -Wl,-z,now -Wl,-z,pack-relative-relocs -fuse-ld=lld}"

REMAP_FLAGS=(
	# "-ffile-prefix-map=$PWD=. -ffile-prefix-map=./=" ?
	"-ffile-prefix-map=$SRCDIR=."
)
EXTRA_FLAGS=(
	"-Wno-error=bad-function-cast"
	"-Wno-error=declaration-after-statement"
	"-Wno-error=switch-enum"
	# "-Wno-error=discarded-qualifiers"  # gcc
	"-Wno-error=ignored-qualifiers"  # clang
)

export CC="$CC"
export CXX="$CXX"
export CFLAGS="$CFLAGS ${REMAP_FLAGS[*]} ${EXTRA_FLAGS[*]}"
export CXXFLAGS="$CXXFLAGS ${REMAP_FLAGS[*]} ${EXTRA_FLAGS[*]}"
export LDFLAGS="$LDFLAGS"
export KCFLAGS="${REMAP_FLAGS[*]}"
export USERCFLAGS="$CFLAGS ${REMAP_FLAGS[*]} ${EXTRA_FLAGS[*]}"
export USERLDFLAGS="$LDFLAGS"

# ---------------------------------------------------------------------------
# Helpers to run make for the kernel and tools builds
# ---------------------------------------------------------------------------

# Helper: run make with necessary variables to build the kernel
kmake() {
	local -
	set -x
	/usr/bin/make \
		"${MAKEVARS[@]}" \
		"$@" \
		"${ARG_MAKEVARS[@]}" \
		# EOL
}

# Helper: run make under bear with necessary variables to build userspace tools
bmake() {
	local -
	set -x
	"${BEAR[@]}" /usr/bin/make \
		"${MAKEVARS[@]}" \
		"$@" \
		"${ARG_MAKEVARS[@]}" \
		# EOL
}


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

quote_or_else() {
	local default="$1"
	shift
	if [[ $1 ]]
	then echo "${1@Q}"
	else echo "$default"
	fi
}
quote_or_else_array() {
	local default="$1"
	shift
	if (( $# ))
	then echo "${*@Q}"
	else echo "$default"
	fi

}

{
	for var in CC CXX CFLAGS CXXFLAGS LDFLAGS RUSTFLAGS; do
		echo "\$$var"$'\t'"$(quote_or_else "(unset)" "${!var}")"
	done
	echo $'------------------------------\t---'
	for c in "${COMPONENTS[@]}"; do
		echo "Building $c"$'\t'"$(want "$c" && echo yes || echo no)${TARGETS[$c]:+ (targets: ${TARGETS[$c]})}"
	done
	echo $'------------------------------\t---'
	echo "Creating compile_commands.json"$'\t'"$(want_cdb && echo yes || echo no)"
	echo "Kernel targets"$'\t'"${KERNEL_TARGETS[*]}"
	echo "Extra make arguments"$'\t'"$(quote_or_else_array "(none)" "${ARG_MAKEVARS[@]}")"
} | column -Lt -s $'\t'

if [[ ${ARG_HELP+set} ]]; then
	exit
fi


# ============================= kernel ======================================
if want kernel; then
	log 'kernel'
	kmake LLVM=1 "${KERNEL_TARGETS[@]}" "$@"
fi

# ============================= tools =======================================

# --- perf ------------------------------------------------------------------
if want perf; then
	log 'perf'
(
	cd tools/perf
	bmake -f Makefile.perf \
		prefix=/usr \
		lib=lib/perf \
		perfexecdir=lib/perf \
		WERROR=0 \
		EXTRA_CFLAGS=" ${REMAP_FLAGS[*]} ${EXTRA_FLAGS[*]}" \
		NO_SDT=1 \
		BUILD_BPF_SKEL=1 \
		PYTHON=python \
		NO_LIBLLVM=1 \
		PYTHON_CONFIG=python-config \
		LIBPFM4=1 \
		${TARGETS[perf]} \
		# EOL
)
fi

# --- cpupower --------------------------------------------------------------
if want cpupower; then
	log 'cpupower'
	(cd tools/power/cpupower && bmake ${TARGETS[cpupower]})
fi

# --- x86_energy_perf_policy -------------------------------------------------
if want x86; then
	log 'x86_energy_perf_policy'
	(cd tools/power/x86/x86_energy_perf_policy && bmake ${TARGETS[x86]})
fi

# --- usbip ------------------------------------------------------------------
if want usbip; then
	log 'usbip'
(
	cd tools/usb/usbip
	if [[ ! -f configure ]]; then
		./autogen.sh
	fi
	if [[ ! -f Makefile ]]; then
		./configure --prefix=/usr --sbindir=/usr/bin
	fi
	bmake ${TARGETS[usbip]}
)
fi

# --- tmon -------------------------------------------------------------------
if want tmon; then
	log 'tmon'
	(cd tools/thermal/tmon && bmake ${TARGETS[tmon]})
fi

# --- turbostat --------------------------------------------------------------
if want turbostat; then
	log 'turbostat'
	(cd tools/power/x86/turbostat && bmake ${TARGETS[turbostat]})
fi

# --- hv ---------------------------------------------------------------------
if want hv; then
	log 'hv'
	(cd tools/hv && CFLAGS="$CFLAGS -DKVP_SCRIPTS_PATH=\\\"/usr/lib/hypervkvpd/\\\"" bmake ${TARGETS[hv]})
fi

# --- bpf / bpftool ----------------------------------------------------------
if want bpf; then
	log 'bpf'
(
	cd tools/bpf
	bmake -C bpftool all doc \
		EXTRA_CFLAGS=" ${REMAP_FLAGS[*]} ${EXTRA_FLAGS[*]}" \
		${TARGETS[bpf]} \
		|| true
		# EOL
	bmake -W runqslower \
		|| true
)
fi

# --- bootconfig -------------------------------------------------------------
if want bootconfig; then
	log 'bootconfig'
	(cd tools/bootconfig && bmake ${TARGETS[bootconfig]})
fi

# --- intel-speed-select -----------------------------------------------------
if want intel-sst; then
	log 'intel-speed-select'
	(cd tools/power/x86/intel-speed-select && bmake ${TARGETS[intel-sst]})
fi

# --- kcpuid -----------------------------------------------------------------
if want kcpuid; then
	log 'kcpuid'
	(cd tools/arch/x86/kcpuid && bmake ${TARGETS[kcpuid]})
fi

log 'done'
